{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waypoint",
  "version": "1.0.0",
  "identifier": "com.waypoint.mvp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "waypoint",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "theme": "Light",
        "titleBarStyle": "Transparent",
        "backgroundColor": "#ececea"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
